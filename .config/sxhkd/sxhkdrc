# Basic binds
alt + Return
	$TERMINAL
alt + d
   j4-dmenu-desktop
alt + shift + d
  dmenu_run
alt + control + d
  (cd ~/desk && ls -1 --color=never | dmenu -l 20 -fn Monospace-16 | xargs -d '\n' xdg-open)  
alt + p
	passmenu -fn Monospace-10
alt + f
	$TERMINAL -e $FILE
alt + shift + f
  $TERMINAL -e mc
alt + e
	$TERMINAL -e neomutt
alt + shift + e
  thunderbird
alt + m
	$TERMINAL -e ncmpcpp
alt + a
  $TERMINAL -e abook --config "$XDG_CONFIG_HOME"/abook/abookrc --datafile "$HOME"/Dropbox/apps/abook/addressbook
alt + shift + a
  $TERMINAL -e pulsemixer
alt + c
	calibre
alt + shift + c
	camtoggle
alt + b
  $BROWSER
alt + shift + b
  qutebrowser  
alt + control + b
  $TERMINAL -e w3m duckduckgo.com
alt + n
  $TERMINAL -e nmtui
alt + shift + n
  sudo systemctl restart NetworkManager
alt + r
  $TERMINAL -e newsboat
alt + shift + r
  $TERMINAL -e podboat
alt + control + r
  $TERMINAL -e rtv
alt + t
	$TERMINAL -e bash -c 'task;$SHELL'
alt + shift + t
  $TERMINAL -e transmission-remote-cli
alt + o
  libreoffice
alt + s
  signal-desktop
alt + Print
  scrot ~/pics/screenshots/%Y-%m-%d-%T-screenshot.png
alt + shift + Print
  sleep 0.2; scrot -s ~/pics/screenshots/%Y-%m-%d-%T-screenshot.png
alt + grave
	dmenuunicode
XF86AudioMute
  pactl set-sink-mute 0 toggle
XF86AudioLowerVolume
  pactl set-sink-volume 0 -5% ; pkill -RTMIN+4 dwmblocks
control+XF86AudioLowerVolume
  pactl set-sink-volume 0 -1% ; pkill -RTMIN+4 dwmblocks
XF86AudioRaiseVolume
  pactl set-sink-volume 0 +5% ; pkill -RTMIN+4 dwmblocks
control+XF86AudioRaiseVolume
  pactl set-sink-volume 0 +1% ; pkill -RTMIN+4 dwmblocks
XF86MonBrightnessDown
  xbacklight -dec 10
XF86MonBrightnessUp
  xbacklight -inc 10
alt + bracketright
  ~/.config/screenlayout/docked.sh
alt + bracketleft
  ~/.config/screenlayout/default.sh

# for X230, etc.
XF86TouchpadToggle
  toggletouchpad
# for X1
XF86Display
  toggletouchpad

