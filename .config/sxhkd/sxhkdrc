# Basic binds
super + Return
	$TERMINAL
super + d
  i3-dmenu-desktop --dmenu='dmenu -i -fn Monospace-10'
super + shift + d
  (cd ~/Desktop && ls -1 --color=never | dmenu -l 20 -fn Monospace-16 | xargs -d '\n' xdg-open)  
super + p
	passmenu -fn Monospace-10
super + f
	$TERMINAL -e $FILE
super + shift + f
  pcmanfm
super + control + f
  $TERMINAL -e mc
super + e
	$TERMINAL -e neomutt
super + shift + e
  thunderbird
super + m
	$TERMINAL -e ncmpcpp
super + a
  $TERMINAL -e pulsemixer
super + c
	calibre
super + shift + c
	camtoggle
super + b
  $BROWSER
super + shift + b
  qutebrowser  
super + control + b
  $TERMINAL -e w3m duckduckgo.com
super + n
  $TERMINAL -e nmtui
super + shift + n
  sudo systemctl restart NetworkManager
super + r
  $TERMINAL -e newsboat
super + shift + r
   $TERMINAL -e podboat
super + t
  $TERMINAL -e vim ~/Documents/notes/org.md
super + shift + t
  $TERMINAL -e transmission-remote-cli
super + o
  libreoffice
super + s
  signal-desktop
super + Print
  scrot ~/Pictures/screenshots/%Y-%m-%d-%T-screenshot.png
super + shift + Print
  sleep 0.2; scrot -s ~/Pictures/screenshots/%Y-%m-%d-%T-screenshot.png
super + grave
	dmenuunicode
XF86AudioMute
  pactl set-sink-mute 0 toggle
XF86AudioLowerVolume
  pactl set-sink-volume 0 -5%
control+XF86AudioLowerVolume
  pactl set-sink-volume 0 -1%
XF86AudioRaiseVolume
  pactl set-sink-volume 0 +5%
control+XF86AudioRaiseVolume
  pactl set-sink-volume 0 +1%
XF86MonBrightnessDown
  xbacklight -dec 10
XF86MonBrightnessUp
  xbacklight -inc 10
super + bracketright
  ~/.screenlayout/docked.sh
super + bracketleft
  ~/.screenlayout/default.sh

# for X230, etc.
XF86TouchpadToggle
  toggletouchpad
# for X1
XF86Display
  toggletouchpad

