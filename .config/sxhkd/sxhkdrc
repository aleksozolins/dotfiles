# Basic binds
super + Return
	$TERMINAL
super + d
   j4-dmenu-desktop
super + shift + d
  dmenu_run
super + control + d
  (cd ~/desk && ls -1 --color=never | dmenu -l 20 -fn Monospace-16 | xargs -d '\n' xdg-open)  
super + p
	passmenu -fn Monospace-10
super + f
	$TERMINAL -e $FILE
super + shift + f
  thunar 
super + control + f
  $TERMINAL -e mc
super + e
	$TERMINAL -e neomutt
super + shift + e
  thunderbird
super + m
	$TERMINAL -e ncmpcpp
super + a
  $TERMINAL -e abook --config "$XDG_CONFIG_HOME"/abook/abookrc --datafile "$HOME"/Dropbox/apps/abook/addressbook
super + shift + a
  $TERMINAL -e pulsemixer
super + c
	calibre
super + shift + c
	camtoggle
super + b
  $BROWSER
super + shift + b
  qutebrowser  
super + control + b
  $TERMINAL -e w3m duckduckgo.com
super + n
  $TERMINAL -e nmtui
super + shift + n
  sudo systemctl restart NetworkManager
super + r
  $TERMINAL -e newsboat
super + shift + r
  $TERMINAL -e podboat
super + control + r
  $TERMINAL -e rtv
super + t
	$TERMINAL -e bash -c 'task;$SHELL'
super + shift + t
  $TERMINAL -e tremc
super + o
  libreoffice
super + s
  signal-desktop
super + Print
  scrot ~/pics/screenshots/%Y-%m-%d-%T-screenshot.png
super + shift + Print
  sleep 0.2; scrot -s ~/pics/screenshots/%Y-%m-%d-%T-screenshot.png
super + grave
	dmenuunicode
XF86AudioMute
  pactl set-sink-mute 0 toggle
XF86AudioLowerVolume
  pactl set-sink-volume 0 -5% ; pkill -RTMIN+4 dwmblocks
control+XF86AudioLowerVolume
  pactl set-sink-volume 0 -1% ; pkill -RTMIN+4 dwmblocks
XF86AudioRaiseVolume
  pactl set-sink-volume 0 +5% ; pkill -RTMIN+4 dwmblocks
control+XF86AudioRaiseVolume
  pactl set-sink-volume 0 +1% ; pkill -RTMIN+4 dwmblocks
XF86MonBrightnessDown
  xbacklight -dec 10
XF86MonBrightnessUp
  xbacklight -inc 10
super + bracketright
  ~/.config/screenlayout/docked.sh
super + bracketleft
  ~/.config/screenlayout/default.sh

# for X230, etc.
XF86TouchpadToggle
  toggletouchpad
# for X1
XF86Display
  toggletouchpad

