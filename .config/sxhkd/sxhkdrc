# Basic binds
super + Return
	$TERMINAL
super + d
  i3-dmenu-desktop	
super + shift + d
  (cd ~/Desktop && ls --color=never | dmenu -l 20 -fn Monospace-16 | xargs xdg-open)  
super + p
	passmenu
super + f
	$TERMINAL -e $FILE
super + shift + f
  pcmanfm
super + e
	$TERMINAL -e neomutt
super + shift + e
  thunderbird
super + m
	$TERMINAL -e ncmpcpp
super + i
	$TERMINAL -e htop
super + a
  $TERMINAL -e pulsemixer
super + c
	camtoggle
super + b
  $TERMINAL -e w3m duckduckgo.com
super + shift + b
  $BROWSER
super + n
  $TERMINAL -e nmtui
super + shift + n
  sudo systemctl restart NetworkManager
super + r
  $TERMINAL -e newsboat
# super + shift + r
#   $TERMINAL -e podboat
super + o
  libreoffice

# Et cetera...
super + grave
	dmenuunicode
XF86AudioMute
  pactl set-sink-mute 0 toggle
XF86AudioLowerVolume
  pactl set-sink-volume 0 -5%
control+XF86AudioLowerVolume
  pactl set-sink-volume 0 -1%
XF86AudioRaiseVolume
  pactl set-sink-volume 0 +5%
control+XF86AudioRaiseVolume
  pactl set-sink-volume 0 +1%
XF86MonBrightnessDown
  xbacklight -dec 10
XF86MonBrightnessUp
  xbacklight -inc 10
super + bracketright
  ~/.screenlayout/docked.sh
super + bracketleft
  ~/.screenlayout/default.sh

# for X230, etc.
XF86TouchpadToggle
  toggletouchpad
# for X1
XF86Display
  toggletouchpad
